# =============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# Copy this file to .env for local development
# NEVER commit .env to git (it's in .gitignore)
# =============================================================================

# -----------------------------------------------------------------------------
# AWS WAF CAPTCHA (Frontend)
# -----------------------------------------------------------------------------
# From the WAF console "Application integration" page for the prod distribution
# (the 2b outputs waf_captcha_integration_url + waf_captcha_api_key). The integration
# URL loads the CAPTCHA JS SDK; it is public and safe to expose in frontend code.
VITE_WAF_INTEGRATION_URL=https://<integration-id>.<region>.captcha-sdk.awswaf.com/<integration-id>/jsapi.js

# -----------------------------------------------------------------------------
# Cloudflare API (Deployment Only - NEVER commit actual values)
# -----------------------------------------------------------------------------
# Get API token from: https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: Cloudflare Pages (Edit), Workers Scripts (Edit)
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id-here

# -----------------------------------------------------------------------------
# Worker Environment Variables (Phase 2)
# -----------------------------------------------------------------------------
# These are injected into the Worker by Terraform at deploy time
# They are NOT used in the frontend Vite app
# DO NOT put actual values here - Terraform injects them from terraform.tfvars
#
# CONTACT_EMAIL=<your-recipient-inbox>   (set via terraform.tfvars, not here)

# -----------------------------------------------------------------------------
# Development Notes
# -----------------------------------------------------------------------------
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env (which is gitignored)
# 3. For Worker secrets, use Terraform variables instead
# 4. Site key is safe to commit (it's public), but NEVER commit the secret key